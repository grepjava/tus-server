DATABASE_URL=sqlite:tus.db
STORAGE_DIR=uploads
BASE_URL=http://localhost:3000
BIND_ADDR=0.0.0.0:3000
MAX_UPLOAD_BYTES=107374182400
ABANDONED_AFTER_HOURS=24
CLEANUP_INTERVAL_SECS=3600
RUST_LOG=info

