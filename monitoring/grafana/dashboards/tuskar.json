{
  "title": "Tuskar — File Transfer Server",
  "uid": "tuskar-main",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "tags": ["tuskar", "uploads"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uploads Created",
      "gridPos": { "x": 0, "y": 0, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{ "expr": "sum(tus_uploads_created_total{context=~\"$context\"})", "legendFormat": "Created", "datasource": { "type": "prometheus", "uid": "${datasource}" } }],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Uploads Completed",
      "gridPos": { "x": 3, "y": 0, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [{ "expr": "sum(tus_uploads_completed_total{context=~\"$context\"})", "legendFormat": "Completed", "datasource": { "type": "prometheus", "uid": "${datasource}" } }],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Uploads",
      "gridPos": { "x": 6, "y": 0, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }, { "color": "yellow", "value": 10 }, { "color": "orange", "value": 50 }] }
        }
      },
      "targets": [{ "expr": "sum(tus_active_uploads_by_context{context=~\"$context\"})", "legendFormat": "Active", "datasource": { "type": "prometheus", "uid": "${datasource}" } }],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Bytes Uploaded",
      "gridPos": { "x": 9, "y": 0, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "fixed", "fixedColor": "cyan" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "cyan", "value": null }] }
        }
      },
      "targets": [{ "expr": "sum(tus_bytes_uploaded_total{context=~\"$context\"})", "legendFormat": "Bytes", "datasource": { "type": "prometheus", "uid": "${datasource}" } }],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Processing Failures",
      "gridPos": { "x": 12, "y": 0, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "sum(tus_processing_failures_total{context=~\"$context\"})", "legendFormat": "Failures", "datasource": { "type": "prometheus", "uid": "${datasource}" } }],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Webhook Failures",
      "gridPos": { "x": 15, "y": 0, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "tus_webhook_deliveries_total{outcome='failure'}", "legendFormat": "Webhook failures", "datasource": { "type": "prometheus", "uid": "${datasource}" } }],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Upload Rate",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Completed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Created" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "Failures" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "targets": [
        { "expr": "sum(rate(tus_uploads_created_total{context=~\"$context\"}[2m]))", "legendFormat": "Created", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "sum(rate(tus_uploads_completed_total{context=~\"$context\"}[2m]))", "legendFormat": "Completed", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "sum(rate(tus_processing_failures_total{context=~\"$context\"}[2m]))", "legendFormat": "Failures", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Bytes Uploaded / s",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "fixed", "fixedColor": "cyan" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        }
      },
      "targets": [
        { "expr": "sum(rate(tus_bytes_uploaded_total{context=~\"$context\"}[2m]))", "legendFormat": "Throughput", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Active & Processing Uploads",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Active" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "Processing" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "targets": [
        { "expr": "sum(tus_active_uploads_by_context{context=~\"$context\"})", "legendFormat": "Active", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "sum(tus_processing_uploads_by_context{context=~\"$context\"})", "legendFormat": "Processing", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Webhook Deliveries / s",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "targets": [
        { "expr": "rate(tus_webhook_deliveries_total{outcome='success'}[2m])", "legendFormat": "Success", "datasource": { "type": "prometheus", "uid": "${datasource}" } },
        { "expr": "rate(tus_webhook_deliveries_total{outcome='failure'}[2m])", "legendFormat": "Failure", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Per-Context Breakdown",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Upload Rate by Context",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity" }
        }
      },
      "targets": [
        { "expr": "rate(tus_uploads_created_total[2m])", "legendFormat": "{{context}}", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Bytes Uploaded / s by Context",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity" }
        }
      },
      "targets": [
        { "expr": "rate(tus_bytes_uploaded_total[2m])", "legendFormat": "{{context}}", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Active Uploads by Context",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 7 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        { "expr": "tus_active_uploads_by_context", "legendFormat": "{{context}}", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Processing Failures by Context",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 7 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "targets": [
        { "expr": "rate(tus_processing_failures_total[2m])", "legendFormat": "{{context}}", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "datasource": { "type": "prometheus", "uid": "${datasource}" }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource",
        "refresh": 1
      },
      {
        "name": "context",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": { "query": "label_values(tus_uploads_created_total, context)", "refId": "A" },
        "current": {},
        "hide": 0,
        "label": "Context",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1
      }
    ]
  }
}
